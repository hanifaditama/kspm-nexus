# Frontend-safe Supabase configuration. Never put a service-role key in a VITE_ variable.
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Configure these as Supabase Edge Function secrets, not frontend deployment variables.
RESEND_API_KEY=re_your_resend_api_key

# Account creation and recovery Edge Functions.
APP_URL=https://your-kspm-site.example
KSPM_EMAIL_DOMAIN=kspm.uph.edu
ACCOUNT_FROM_EMAIL=KSPM Nexus <account@your-verified-domain.example>
ACCOUNT_HASH_SALT=replace-with-a-long-random-secret
