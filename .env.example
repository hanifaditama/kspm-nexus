# Frontend-safe Supabase configuration. Never put a service-role key in a VITE_ variable.
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-or-publishable-key

# Configure these as Supabase Edge Function secrets, not frontend deployment variables.
RESEND_API_KEY=re_your_resend_api_key
CONTACT_FROM_EMAIL=KSPM Nexus <contact@your-verified-domain.example>
CONTACT_HASH_SALT=replace-with-a-long-random-secret
